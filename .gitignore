/.bundle/
/vendor/

# Native build artifacts (any nesting level, matching kobako's rules):
# cargo target dirs, C objects, static libs (libmruby.a), and Ruby
# native-extension outputs with their mkmf build log.
target/
*.o
*.a
*.so
*.bundle
mkmf.log

# rbs collection install destination, regenerable from the committed
# lockfile once RBS + steep land (kobako convention).
/.gem_rbs_collection/
/.yardoc
/_yardoc/
/coverage/
/doc/
/pkg/
/spec/reports/
/tmp/
