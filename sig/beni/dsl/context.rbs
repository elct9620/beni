module Beni
  module DSL
    class Context
      @settings: Hash[Symbol, String]
      @targets: Hash[String, Target]
      @definitions: Hash[String, ToolchainDefinition]

      def initialize: () -> void

      def version: (String value) -> void

      def build_config: (String path) -> void

      def vendor_dir: (String path) -> void

      def target: (Symbol | String name) ?{ () [self: TargetContext] -> void } -> void

      def toolchain: (Symbol | String name) ?{ () [self: DefinitionContext] -> void } -> void

      def configuration: () -> Configuration

      private

      def declare_scalar: (Symbol key, String value) -> void

      def resolved_vendor_dir: () -> String

      def resolved_build_config: () -> String?

      def resolved_targets: () -> Array[String]

      def selected_names: () -> Array[String]

      def selected_toolchain: (String name) -> SelectedToolchain

      def mruby_version: () -> String
    end
  end
end
