# frozen_string_literal: true

# Consumer scenario: the gem's customization path, end to end.
#
# A consumer who needs more than the upstream defaults runs
# `rake beni:config` to materialize the configured version's upstream
# default config, edits the generated file — here appending a
# wasm32-wasip1 cross target, which also pulls in the wasi-sdk
# toolchain — and points Beni::Tasks at it. Unlike the repo-root
# Rakefile (whose config is committed), this drives the generate →
# edit → build chain through the gem's task interface alone. Run from
# this directory:
#
#   $ cd test/scenarios/generated_config && rake scenario:setup beni:build scenario:verify
$LOAD_PATH.unshift File.expand_path("../../../lib", __dir__)

require "beni/tasks"

CONFIG = File.expand_path("build_config/mruby.rb", __dir__)

Beni::Tasks.new do
  build_config CONFIG

  target :host
  target :wasi do
    toolchain "wasi-sdk"
  end
end

# The consumer's hand-edit, appended below the generated upstream
# default config: a wasm32-wasip1 cross target. `conf.toolchain :wasi`
# resolves to the wasi toolchain file `beni:vendor:setup` stages into
# the mruby tree. Mirrors the README's cross-target example.
WASI_CROSS_TARGET = <<~CONFIG_SNIPPET

  # ---- consumer-added wasm32-wasip1 cross target ------------------------
  MRuby::CrossBuild.new("wasi") do |conf|
    conf.toolchain :wasi
  end
CONFIG_SNIPPET

namespace :scenario do
  desc "Generate the build config and append the consumer's wasi cross target"
  task :setup do
    next if File.exist?(CONFIG)

    Rake::Task["beni:vendor:setup"].invoke
    Rake::Task["beni:config"].invoke
    File.write(CONFIG, WASI_CROSS_TARGET, mode: "a")
  end

  desc "Assert the artifacts beni:build must leave behind"
  task :verify do
    artifacts = [CONFIG] + %w[
      vendor/mruby/build/host/lib/libmruby.a
      vendor/mruby/build/host/lib/libmruby.flags.mak
      vendor/mruby/build/wasi/lib/libmruby.a
      vendor/mruby/build/wasi/lib/libmruby.flags.mak
    ].map { |rel| File.expand_path(rel, __dir__) }

    missing = artifacts.reject { |path| File.exist?(path) }
    abort "[scenario] missing artifacts:\n  #{missing.join("\n  ")}" unless missing.empty?

    puts "[scenario] generated_config artifacts verified: #{artifacts.join(", ")}"
  end
end
